---------------------------
-- Classify and compare the two population 
-- P25/P75 test and mean-median gap test to confirm bimodal distribution for the whole dataset and for the populations
---------------------------

Select
    case when DAYOFWEEK(t.posting_date) IN (0, 6) or h.holiday_date is not null THEN 'Weekend/bank holiday'
         when volume_gbp < 10000 THEN 'Atypical business days' -- weekdays with atypical transfer volumes (arbitrary)
    else 'Business day'
    end as population,
    count(*) as n,
    round(avg(volume_gbp), 0) as mean,
    round(median(volume_gbp), 0) as median, 
    round(stddev(volume_gbp), 0) as std_dev,
    percentile_cont(0.25) within group (order by volume_gbp) as p25,
    percentile_cont(0.50) within group (order by volume_gbp) as p50,
    percentile_cont(0.75) within group (order by volume_gbp) as p75,
from  dash_case_study.wise_case_study.take_home_task_dataset t
left join dash_case_study.wise_case_study.holidays_2023 h 
    on t.posting_date = h.holiday_date
group by 1
;
