---------------------------
-- Null values 
---------------------------
-- A total of 10 days returned zero values: the majority were weekends, and two Fridays were public holidays.

select 
    posting_date,
    date_trunc(month, posting_date) as posting_month,
    date_trunc(quarter, posting_date) as posting_quarter,
    dayname(posting_date) as day_of_week,
    round(volume_gbp,3) as volume_gbp,
    sum(case when volume_gbp=0 then 1 else 0 end) as no_days_with_zero
from dash_case_study.wise_case_study.take_home_task_dataset
group by 1, volume_gbp
having no_days_with_zero!=0 
;

